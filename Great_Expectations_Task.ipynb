          "text": [
            "INFO:great_expectations.data_context.types.base:Created temporary directory '/tmp/tmpw4psjd76' for ephemeral docs site\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "##6. Define and Create a Data Batch"
      ],
      "metadata": {
        "id": "IHl4W07zJ5-A"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "batch_definition = data_asset.add_batch_definition_whole_dataframe(\"labels_batch_definition\")\n",
        "batch = batch_definition.get_batch(batch_parameters={\"dataframe\": df})"
      ],
      "metadata": {
        "id": "dTdpe1tVhpgp",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "63c04dc3-34c2-498c-c683-6543cf2cfba7"
